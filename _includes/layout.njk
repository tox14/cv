<!doctype html>
<html lang="{{ lang }}">
  <head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>{{ data[lang].title }}</title>
    <meta name="description" content="{{ data[lang].description }}"/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@200..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles.css"/>
  </head>
  <body>
    <div class="container">
      <header class="block">
        <div class="block__left bordered">
          <h2 class="document-type">{{ data[lang].resume }}</h2>
        </div>
        <div class="block__right">
          <h1 class="document-title">{{ data[lang].name }}</h1>
          <h2 class="document-position">{{ data[lang].position }}</h2>
        </div>
      </header>
      <div class="block">
        <div class="block__left">
          <picture>
            {% for image in data[lang].photo.sources %}
              <source srcset="{{ image.src }}" type="{{ image.type }}">
            {% endfor %}
            <img class="document-photo" src="{{ data[lang].photo.default_src }}" alt="{{ data[lang].photo.alt }}">
          </picture>
        </div>
        <div class="block__right">
          <div class="contacts">
            {% for contact in data[lang].contacts %}
              <a class="contact-item" href="{{ contact.href }}" data-label="{{ contact.label }}">{{ contact.text }}</a>
            {% endfor %}
          </div>
        </div>
      </div>
      <main>
        <section class="block" style="margin: 40px 0 50px;">
          <div class="block__left bordered">
            <p class="location-country">
              <img src="/assets/images/location_icon.svg" alt="" aria-hidden="true"/>
              {{ data[lang].location.country }}
            </p>
            <p class="location-city">{{ data[lang].location.city }}</p>
          </div>
          <div class="block__right">
            <h2 class="block__title">{{ data[lang].about.title }}</h2>
            <p class="block__text">{{ data[lang].about.text }}</p>
          </div>
        </section>
        <section class='block' style="margin-bottom: 10px">
          <div class="block__left">
            <h2 class="block__title">{{ data[lang].skills_label }}</h2>
          </div>
          <div class="block__right">
            <h2 class="block__title">{{ data[lang].experience_label }}</h2>
          </div>
        </section>
        {% for experience in data[lang].experience %}
          <section class='block'>
            <div class="block__left bordered">
              {% if experience.hook %}
                <h2 class="block__subtitle">{{ experience.hook | safe }}</h2>
              {% endif %}
              {% for skill in experience.skills %}
                <p class="block__text">{{ skill }}</p>
              {% endfor %}
            </div>
            <div class="block__right">
              <h3 class="block__subtitle block__subtitle--point">{{ experience.company_name }}</h3>
              <h4 class="block__subtitle">{{ experience.position }} | {{ experience.period }}</h4>
              <div class="block__text">{{ experience.description | safe }}</div>
            </div>
          </section>
        {% endfor %}
        <section class='block' style="margin: 50px 0 10px">
          <div class="block__left">
            <h2 class="block__title">{{ data[lang].languages.label }}</h2>
          </div>
          <div class="block__right">
            <h2 class="block__title">{{ data[lang].education.label }}</h2>
          </div>
        </section>
        <section class='block'>
          <div class="block__left bordered">
            {% for language in data[lang].languages.items %}
              <p class='block__text bordered'>{{ language.name }} ({{ language.level }})</p>
            {% endfor %}
          </div>
          <div class="block__right">
            {% for education in data[lang].education.items %}
              <h3 class='block__subtitle block__subtitle--point'>{{ education.name }}</h3>
              <h3 class='block__subtitle'>{{ education.period }}</h3>
              <div class="block__text">{{ education.description | safe }}</div>
            {% endfor %}
          </div>
        </section>
      </main>
    </div>
    <div class="action-panel">
      <div class="language-switch">
        {% for code, value in data %}
          <a class="language-switch__option{% if lang == code %} active{% endif %}" href="/{{ code }}/">{{ code | upper }}</a>
        {% endfor %}
      </div>
      <button id="download-pdf" class="download-btn" data-file-name="{{ data[lang].name }}_CV.pdf">
        <img src="/assets/images/download_icon.svg" alt="PDF" aria-hidden="true"/>
        <span>PDF</span>
      </button>
    </div>
    <script src="/assets/scripts.js" defer></script>
  </body>
</html>